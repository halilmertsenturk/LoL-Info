RIOT_API_KEY=your_riot_api_key_here
DATABASE_URL=postgresql://user:password@host:5432/lolinfo
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# --- Render bypass (dev key + public site) ---
# Option A: Home proxy (recommended workaround)
# Run locally: npm run proxy:home
# Tunnel: cloudflared tunnel --url http://localhost:8787
# RIOT_PROXY_URL=https://your-tunnel.trycloudflare.com
# RIOT_PROXY_SECRET=choose-a-long-random-secret

# Option B: Cache-only on Render (no live Riot calls)
# RIOT_CACHE_ONLY=true
